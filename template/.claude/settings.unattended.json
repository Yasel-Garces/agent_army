{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Unattended mode (GitHub Actions, scheduled workflows). Stripped MCP, default-ask permissions, no acceptEdits. Use via CLAUDE_SETTINGS_PATH=plugins/yasel-core/settings.unattended.json in the workflow env.",
  "includeCoAuthoredBy": true,
  "env": {
    "INSIDE_CLAUDE_CODE": "1",
    "UNATTENDED_MODE": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "300000"
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [
    "github"
  ],
  "permissions": {
    "defaultMode": "ask",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(jq:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh api:*)",
      "Bash(npm audit:*)",
      "Bash(pnpm audit:*)",
      "Bash(pip-audit:*)",
      "Bash(osv-scanner:*)",
      "Bash(gitleaks:*)",
      "Bash(trufflehog:*)"
    ],
    "deny": [
      "Edit",
      "Write",
      "MultiEdit",
      "NotebookEdit",
      "Bash(rm:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git branch -D:*)",
      "Bash(git clean:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(aws:*)",
      "Bash(terraform:*)",
      "Bash(kubectl:*)",
      "Bash(docker:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "mcp__postgres__*",
      "mcp__linear__*",
      "mcp__notion__*",
      "mcp__slack__*",
      "mcp__sentry__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PLUGIN_ROOT\"/hooks/env-file-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PLUGIN_ROOT\"/hooks/mcp-supervisor.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
